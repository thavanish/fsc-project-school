---
import Base from '../layouts/Base.astro';

const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
---

<Base title="Identify">
  <h1 class="page-title">Identify a Face</h1>
  <p class="page-subtitle">
    One-to-many lookup. Upload a photo and the model searches the entire database
    for the closest match.
  </p>

  <div class="two-col" style="align-items: start;">

    <!-- left: upload + result -->
    <div>
      <div class="card">
        <label>Photo to identify</label>
        <div class="upload-zone" id="upload-zone">
          <input type="file" id="file-input" accept="image/*" />
          <div class="upload-icon">🔍</div>
          <p class="upload-hint">Click or drop an image here</p>
        </div>
        <img id="preview" class="preview-img" alt="Preview" />
        <button class="btn" id="identify-btn" disabled>Identify</button>
      </div>

      <div class="result" id="result">
        <div class="result-title" id="result-title"></div>
        <div class="result-meta" id="result-meta"></div>
        <div class="confidence-bar" id="conf-bar" style="display:none">
          <div class="fill" id="conf-fill"></div>
        </div>
      </div>
    </div>

    <!-- right: registered faces sidebar -->
    <div class="card">
      <h3>Database (<span id="face-count">—</span>)</h3>
      <ul class="face-list" id="face-list">
        <li class="empty">Loading...</li>
      </ul>
      <p style="margin-top: 0.75rem; font-size: 0.82rem;">
        No faces yet? Go to <a href="/register">Register</a> to add some.
      </p>
    </div>

  </div>
</Base>

<script define:vars={{ apiUrl }}>
  const fileInput   = document.getElementById('file-input');
  const uploadZone  = document.getElementById('upload-zone');
  const preview     = document.getElementById('preview');
  const identifyBtn = document.getElementById('identify-btn');
  const result      = document.getElementById('result');
  const resultTitle = document.getElementById('result-title');
  const resultMeta  = document.getElementById('result-meta');
  const confBar     = document.getElementById('conf-bar');
  const confFill    = document.getElementById('conf-fill');
  const faceList    = document.getElementById('face-list');
  const faceCount   = document.getElementById('face-count');

  // ── file selection ─────────────────────────────────────────────────────
  fileInput.addEventListener('change', () => {
    const file = fileInput.files?.[0];
    if (!file) return;
    preview.src = URL.createObjectURL(file);
    preview.classList.add('visible');
    identifyBtn.disabled = false;
  });

  uploadZone.addEventListener('dragover', (e) => { e.preventDefault(); uploadZone.classList.add('dragover'); });
  uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('dragover'));
  uploadZone.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadZone.classList.remove('dragover');
    const file = e.dataTransfer?.files?.[0];
    if (file?.type.startsWith('image/')) {
      const dt = new DataTransfer();
      dt.items.add(file);
      fileInput.files = dt.files;
      preview.src = URL.createObjectURL(file);
      preview.classList.add('visible');
      identifyBtn.disabled = false;
    }
  });

  // ── identify ───────────────────────────────────────────────────────────
  identifyBtn.addEventListener('click', async () => {
    const file = fileInput.files?.[0];
    if (!file) return;

    identifyBtn.disabled = true;
    identifyBtn.textContent = 'Searching...';
    result.className = 'result';
    confBar.style.display = 'none';

    const body = new FormData();
    body.append('image', file);

    try {
      const res  = await fetch(`${apiUrl}/api/identify`, { method: 'POST', body });
      const data = await res.json();

      if (!res.ok) {
        result.classList.add('visible', 'no-match');
        resultTitle.textContent = '✗ Error';
        resultMeta.textContent  = data.detail ?? 'Unknown error';
      } else if (data.faces_detected === 0) {
        result.classList.add('visible', 'warn');
        resultTitle.textContent = '⚠ No face detected';
        resultMeta.innerHTML    = 'The model couldn\'t find a face in this image. Try a clearer, brighter photo.';
      } else if (data.matched) {
        const pct = Math.round(data.confidence * 100);
        result.classList.add('visible', 'match');
        resultTitle.textContent = `✓ Match: ${data.name}`;
        resultMeta.innerHTML    = `Confidence <span>${pct}%</span> &nbsp;·&nbsp; Distance <span>${data.distance}</span>`;
        confBar.style.display   = 'block';
        confFill.style.width    = `${pct}%`;
      } else {
        const pct = Math.round(data.confidence * 100);
        result.classList.add('visible', 'no-match');
        resultTitle.textContent = '✗ No match found';
        resultMeta.innerHTML    = `Best similarity <span>${pct}%</span> — below the match threshold. Register this person first.`;
        confBar.style.display   = 'block';
        confFill.style.width    = `${pct}%`;
        confFill.style.background = 'var(--error)';
      }
    } catch {
      result.classList.add('visible', 'no-match');
      resultTitle.textContent = '✗ Could not reach the backend';
      resultMeta.textContent  = `Check that ${apiUrl} is running`;
    }

    identifyBtn.disabled = false;
    identifyBtn.textContent = 'Identify';
  });

  // ── load face list ─────────────────────────────────────────────────────
  async function loadFaces() {
    try {
      const res  = await fetch(`${apiUrl}/api/faces/`);
      const data = await res.json();
      faceCount.textContent = data.count;
      if (!data.faces.length) {
        faceList.innerHTML = '<li class="empty">No faces registered yet.</li>';
        return;
      }
      faceList.innerHTML = data.faces.map(name => `<li><span>${name}</span></li>`).join('');
    } catch {
      faceList.innerHTML = '<li class="empty">Could not load — backend offline?</li>';
    }
  }

  loadFaces();
</script>
