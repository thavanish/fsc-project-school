---
import Base from '../layouts/Base.astro';

const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
---

<Base title="Verify">
  <header class="page-head">
    <div>
      <p class="eyebrow">Verify</p>
      <h1>Compare two photos.</h1>
      <p class="page-subtitle">
        Check whether two images show the same person. This does not use the saved face list.
      </p>
    </div>
    <aside class="hero-note desktop-only">
      <strong>Two clear faces</strong>
      <p>The result is only useful when both photos contain a face.</p>
    </aside>
  </header>

  <section class="flow">
    <div class="panel input-panel">
      <div class="media-input-grid verify-input-grid">
        <div>
          <div class="section-title-row compact-title-row">
            <div>
              <h2>Camera</h2>
              <p>Capture into either comparison slot.</p>
            </div>
          </div>
          <div class="camera-stage compact-camera" id="camera-stage">
            <video id="camera-feed" autoplay muted playsinline></video>
            <canvas id="camera-canvas"></canvas>
            <div class="camera-empty" id="camera-empty">
              <strong>Camera is off</strong>
              <span>Start it, then choose a slot.</span>
            </div>
          </div>
          <div class="control-row">
            <button class="btn btn-secondary" id="camera-btn" type="button">Start camera</button>
          </div>
          <div class="control-row">
            <button class="btn" id="capture-first-btn" type="button" disabled>Use as first</button>
            <button class="btn" id="capture-second-btn" type="button" disabled>Use as second</button>
          </div>
        </div>

      <div class="verify-grid">
        <div class="field">
          <label for="file1">First photo</label>
          <div class="upload-zone compact-upload" id="zone1">
            <input type="file" id="file1" accept="image/*" />
            <div class="upload-copy">
              <span class="upload-icon">
                <svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                  <circle cx="8.5" cy="8.5" r="1.5"></circle>
                  <path d="M21 15l-5-5L5 21"></path>
                </svg>
              </span>
              <p class="upload-hint">Drop the first face photo</p>
            </div>
          </div>
          <img id="preview1" class="preview-img" alt="First selected face preview" />
        </div>

        <div class="field">
          <label for="file2">Second photo</label>
          <div class="upload-zone compact-upload" id="zone2">
            <input type="file" id="file2" accept="image/*" />
            <div class="upload-copy">
              <span class="upload-icon">
                <svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                  <circle cx="8.5" cy="8.5" r="1.5"></circle>
                  <path d="M21 15l-5-5L5 21"></path>
                </svg>
              </span>
              <p class="upload-hint">Drop the second face photo</p>
            </div>
          </div>
          <img id="preview2" class="preview-img" alt="Second selected face preview" />
        </div>
      </div>
      </div>

      <div class="selection-dock">
        <div>
          <span class="dock-label">Ready to compare</span>
          <strong id="selection-state">Choose two photos</strong>
        </div>
        <button class="btn btn-fit" id="verify-btn" disabled>Compare faces</button>
      </div>
    </div>

    <div class="result" id="result">
      <div class="result-title" id="result-title"></div>
      <div class="result-meta" id="result-meta"></div>
      <div class="confidence-bar" id="conf-bar" hidden>
        <div class="fill" id="conf-fill"></div>
      </div>
    </div>

    <div class="panel panel-muted">
      <h2>How to read the score</h2>
      <p>
        Distance is the gap between the two face embeddings. Below 0.55 counts as the same person.
        Confidence is a quick similarity score, so higher is better.
      </p>
    </div>
  </section>
</Base>

<script define:vars={{ apiUrl }}>
  const file1Input = document.getElementById('file1');
  const file2Input = document.getElementById('file2');
  const zone1 = document.getElementById('zone1');
  const zone2 = document.getElementById('zone2');
  const cameraBtn = document.getElementById('camera-btn');
  const captureFirstBtn = document.getElementById('capture-first-btn');
  const captureSecondBtn = document.getElementById('capture-second-btn');
  const video = document.getElementById('camera-feed');
  const canvas = document.getElementById('camera-canvas');
  const cameraEmpty = document.getElementById('camera-empty');
  const preview1 = document.getElementById('preview1');
  const preview2 = document.getElementById('preview2');
  const verifyBtn = document.getElementById('verify-btn');
  const selectionState = document.getElementById('selection-state');
  const result = document.getElementById('result');
  const resultTitle = document.getElementById('result-title');
  const resultMeta = document.getElementById('result-meta');
  const confBar = document.getElementById('conf-bar');
  const confFill = document.getElementById('conf-fill');
  let stream = null;
  let firstFile = null;
  let secondFile = null;

  function apiBase() {
    return window.faceLabBackend?.apiUrl ?? apiUrl.replace(/\/$/, '');
  }

  async function waitForBackend() {
    await window.faceLabBackend?.ready;
  }

  function checkReady() {
    const ready = Boolean(firstFile && secondFile);
    verifyBtn.disabled = !ready;
    selectionState.textContent = ready ? 'Both photos selected' : firstFile || secondFile ? 'One more photo needed' : 'Choose two photos';
  }

  function setSlot(slot, file, preview) {
    if (!file) return;
    if (slot === 'first') firstFile = file;
    else secondFile = file;
    preview.src = URL.createObjectURL(file);
    preview.classList.add('visible');
    checkReady();
  }

  async function startCamera() {
    try {
      stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' }, audio: false });
      video.srcObject = stream;
      cameraEmpty.classList.add('hidden');
      cameraBtn.textContent = 'Stop camera';
      captureFirstBtn.disabled = false;
      captureSecondBtn.disabled = false;
    } catch {
      result.classList.add('visible', 'no-match');
      resultTitle.textContent = 'Camera blocked';
      resultMeta.textContent = 'Allow camera access or upload both photos instead.';
    }
  }

  function stopCamera() {
    stream?.getTracks().forEach((track) => track.stop());
    stream = null;
    video.srcObject = null;
    cameraEmpty.classList.remove('hidden');
    cameraBtn.textContent = 'Start camera';
    captureFirstBtn.disabled = true;
    captureSecondBtn.disabled = true;
  }

  function captureToSlot(slot) {
    if (!stream || !video.videoWidth) return;
    canvas.width = video.videoWidth;
    canvas.height = video.videoHeight;
    canvas.getContext('2d').drawImage(video, 0, 0);
    canvas.toBlob((blob) => {
      if (!blob) return;
      const file = new File([blob], `${slot}-verify-${Date.now()}.jpg`, { type: 'image/jpeg' });
      setSlot(slot, file, slot === 'first' ? preview1 : preview2);
    }, 'image/jpeg', 0.92);
  }

  cameraBtn.addEventListener('click', () => {
    if (stream) stopCamera();
    else startCamera();
  });

  captureFirstBtn.addEventListener('click', () => captureToSlot('first'));
  captureSecondBtn.addEventListener('click', () => captureToSlot('second'));

  function setupInput(input, zone, preview, slot) {
    input.addEventListener('change', () => setSlot(slot, input.files?.[0], preview));

    zone.addEventListener('dragover', (event) => {
      event.preventDefault();
      zone.classList.add('dragover');
    });

    zone.addEventListener('dragleave', () => zone.classList.remove('dragover'));

    zone.addEventListener('drop', (event) => {
      event.preventDefault();
      zone.classList.remove('dragover');
      const file = event.dataTransfer?.files?.[0];
      if (file?.type.startsWith('image/')) {
        const transfer = new DataTransfer();
        transfer.items.add(file);
        input.files = transfer.files;
        setSlot(slot, file, preview);
      }
    });
  }

  setupInput(file1Input, zone1, preview1, 'first');
  setupInput(file2Input, zone2, preview2, 'second');

  verifyBtn.addEventListener('click', async () => {
    const first = firstFile;
    const second = secondFile;
    if (!first || !second) return;

    verifyBtn.disabled = true;
    verifyBtn.textContent = 'Comparing';
    result.className = 'result';
    confBar.hidden = true;
    confFill.style.background = 'var(--accent)';

    const body = new FormData();
    body.append('image1', first);
    body.append('image2', second);

    try {
      await waitForBackend();
      const res = await fetch(`${apiBase()}/api/verify`, { method: 'POST', body });
      const data = await res.json();

      if (!res.ok) {
        result.classList.add('visible', 'no-match');
        resultTitle.textContent = 'Compare failed';
        resultMeta.textContent = data.detail ?? 'The backend did not explain why.';
      } else if (!data.face1_detected || !data.face2_detected) {
        const missing = !data.face1_detected ? 'first' : 'second';
        result.classList.add('visible', 'warn');
        resultTitle.textContent = 'One photo has no face';
        resultMeta.textContent = `Try a clearer ${missing} photo.`;
      } else {
        const pct = Math.round(data.confidence * 100);
        if (data.same_person) {
          result.classList.add('visible', 'match');
          resultTitle.textContent = 'Same person';
        } else {
          result.classList.add('visible', 'no-match');
          resultTitle.textContent = 'Different people';
          confFill.style.background = 'var(--danger)';
        }
        resultMeta.innerHTML = `Confidence <span>${pct}%</span>, distance <span>${data.distance}</span>`;
        confBar.hidden = false;
        confFill.style.width = `${pct}%`;
      }
    } catch {
      result.classList.add('visible', 'no-match');
      resultTitle.textContent = 'Backend is quiet';
      resultMeta.textContent = `Start the API at ${apiBase()}.`;
    }

    verifyBtn.disabled = false;
    verifyBtn.textContent = 'Compare faces';
  });
</script>
