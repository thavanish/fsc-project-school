---
import Base from '../layouts/Base.astro';

const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
---

<Base title="Register">
  <h1 class="page-title">Register a Face</h1>
  <p class="page-subtitle">
    Add someone to the database. Upload a clear, well-lit photo and give it a name.
    If that name already exists, this overwrites it.
  </p>

  <div class="two-col" style="align-items: start;">

    <!-- left: form -->
    <div>
      <div class="card">
        <div class="field">
          <label for="name-input">Name</label>
          <input type="text" id="name-input" placeholder="e.g. Thavanish" autocomplete="off" />
        </div>

        <div class="field">
          <label>Photo</label>
          <div class="upload-zone" id="upload-zone">
            <input type="file" id="file-input" accept="image/*" />
            <div class="upload-icon">📷</div>
            <p class="upload-hint">Click or drop an image here</p>
          </div>
          <img id="preview" class="preview-img" alt="Preview" />
        </div>

        <button class="btn" id="submit-btn" disabled>Register face</button>
      </div>

      <div class="result" id="result">
        <div class="result-title" id="result-title"></div>
        <div class="result-meta" id="result-meta"></div>
      </div>
    </div>

    <!-- right: current database -->
    <div class="card">
      <h3>Registered faces</h3>
      <ul class="face-list" id="face-list">
        <li class="empty">Loading...</li>
      </ul>
    </div>

  </div>
</Base>

<script define:vars={{ apiUrl }}>
  const nameInput   = document.getElementById('name-input');
  const fileInput   = document.getElementById('file-input');
  const uploadZone  = document.getElementById('upload-zone');
  const preview     = document.getElementById('preview');
  const submitBtn   = document.getElementById('submit-btn');
  const result      = document.getElementById('result');
  const resultTitle = document.getElementById('result-title');
  const resultMeta  = document.getElementById('result-meta');
  const faceList    = document.getElementById('face-list');

  // ── enable submit only when both fields are filled ────────────────────
  function checkReady() {
    submitBtn.disabled = !nameInput.value.trim() || !fileInput.files?.length;
  }

  nameInput.addEventListener('input', checkReady);

  fileInput.addEventListener('change', () => {
    const file = fileInput.files?.[0];
    if (!file) return;
    preview.src = URL.createObjectURL(file);
    preview.classList.add('visible');
    checkReady();
  });

  // ── drag and drop ──────────────────────────────────────────────────────
  uploadZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    uploadZone.classList.add('dragover');
  });

  uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('dragover'));

  uploadZone.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadZone.classList.remove('dragover');
    const file = e.dataTransfer?.files?.[0];
    if (file && file.type.startsWith('image/')) {
      const dt = new DataTransfer();
      dt.items.add(file);
      fileInput.files = dt.files;
      preview.src = URL.createObjectURL(file);
      preview.classList.add('visible');
      checkReady();
    }
  });

  // ── submit ─────────────────────────────────────────────────────────────
  submitBtn.addEventListener('click', async () => {
    const name = nameInput.value.trim();
    const file = fileInput.files?.[0];
    if (!name || !file) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Registering...';
    result.className = 'result';

    const body = new FormData();
    body.append('name', name);
    body.append('image', file);

    try {
      const res  = await fetch(`${apiUrl}/api/faces/register`, { method: 'POST', body });
      const data = await res.json();

      if (res.ok) {
        result.classList.add('visible', 'match');
        resultTitle.textContent = `✓ ${data.message}`;
        resultMeta.textContent  = '';
        nameInput.value = '';
        fileInput.value = '';
        preview.classList.remove('visible');
        await loadFaces();
      } else {
        result.classList.add('visible', 'no-match');
        resultTitle.textContent = '✗ Registration failed';
        resultMeta.textContent  = data.detail ?? 'Unknown error';
      }
    } catch {
      result.classList.add('visible', 'no-match');
      resultTitle.textContent = '✗ Could not reach the backend';
      resultMeta.textContent  = `Check that ${apiUrl} is running`;
    }

    submitBtn.disabled = false;
    submitBtn.textContent = 'Register face';
    checkReady();
  });

  // ── face list ──────────────────────────────────────────────────────────
  async function loadFaces() {
    try {
      const res  = await fetch(`${apiUrl}/api/faces/`);
      const data = await res.json();
      renderFaces(data.faces);
    } catch {
      faceList.innerHTML = '<li class="empty">Could not load — is the backend running?</li>';
    }
  }

  async function deleteFace(name) {
    await fetch(`${apiUrl}/api/faces/${encodeURIComponent(name)}`, { method: 'DELETE' });
    await loadFaces();
  }

  function renderFaces(faces) {
    if (!faces.length) {
      faceList.innerHTML = '<li class="empty">No faces registered yet.</li>';
      return;
    }
    faceList.innerHTML = faces.map(name => `
      <li>
        <span>${name}</span>
        <button class="btn btn-sm" data-name="${name}">Remove</button>
      </li>
    `).join('');

    faceList.querySelectorAll('[data-name]').forEach(btn => {
      btn.addEventListener('click', () => deleteFace(btn.dataset.name));
    });
  }

  loadFaces();
</script>
