# Comma-separated list of allowed origins for CORS.
# Add your Cloudflare Pages URL once deployed.
ALLOWED_ORIGINS=http://localhost:4321,https://your-app.pages.dev

# Match threshold for face comparison (0 to 1).
# Lower = stricter. The face_recognition library defaults to 0.6;
# 0.55 cuts down false positives without hurting real matches much.
MATCH_THRESHOLD=0.55
